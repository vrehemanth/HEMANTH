## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (DotSettings)
*.resharper.user
*.dotSettings.user

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bbin/
obj/
external/
node_modules/
publish/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in the wwwroot
# wwwroot/

# Visual Studio Code
.vscode/

# Compiled files
*.dll
*.exe
*.pdb
*.appref-ms

# Output folders
TestResults/
[Bb]in/
[Oo]bj/

# Entity Framework (Optional: ignore if you don't want to track Migrations Snapshot)
# *.DesignData.json

# User settings files
appsettings.json
appsettings.Development.json
!appsettings.json
!appsettings.Development.json

# Secrets (IMPORTANT)
secrets.json
.env
*.env.json

# OS generated files
.DS_Store
Thumbs.db

# Project-specific logs/temp
*.log
logs/
temp/
